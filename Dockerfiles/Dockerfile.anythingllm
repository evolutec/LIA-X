FROM mintplexlabs/anythingllm:latest

# Configuration LIA préintégrée
ENV STORAGE_DIR=/app/server/storage
ENV LLM_PROVIDER=generic-openai
ENV GENERIC_OPEN_AI_BASE_PATH=http://host.docker.internal:3002/v1
ENV GENERIC_OPEN_AI_MODEL_PREF=lia-local
ENV GENERIC_OPEN_AI_API_KEY=not-used
ENV GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT=8192
ENV EMBEDDING_ENGINE=native
ENV NO_PROXY=model-loader,localhost,127.0.0.1,host.docker.internal
ENV no_proxy=model-loader,localhost,127.0.0.1,host.docker.internal

EXPOSE 3001