FROM ghcr.io/open-webui/open-webui:main

# Configuration LIA préintégrée
ENV WEBUI_AUTH=False
ENV WEBUI_SECRET_KEY=lia-local-secret
ENV ENABLE_OLLAMA_API=false
ENV ENABLE_OPENAI_API=true
ENV OPENAI_API_BASE_URL=http://host.docker.internal:3002/v1
ENV OPENAI_API_BASE_URLS=http://host.docker.internal:3002/v1
ENV OPENAI_API_KEYS=not-used
ENV OPENAI_API_KEY=not-used

# Health check intégré
HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
  CMD curl -fsS http://127.0.0.1:8080/ > /dev/null || exit 1

EXPOSE 8080